# Copy this to .env and fill in your values

# Flask
SECRET_KEY=change-me-to-something-random
PORT=8002
APP_BASE_URL=http://your-pi-hostname-or-ip:8002

# Database (Pi path)
DB_PATH=/home/pi/data/family.db

# Google Calendar OAuth2
# Create credentials at https://console.cloud.google.com/
# App type: Web application, redirect URI: http://your-pi:8002/calendar/oauth2callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Calendar ID is pre-set in config.py — only override if needed
# CALENDAR_ID=

# NTFY channels (optional — can also be set per-person in the app UI)
NTFY_CHANNEL_PAUL=collis-paul-xxxxxxxx
NTFY_CHANNEL_KATIE=collis-katie-xxxxxxxx
NTFY_CHANNEL_FAMILY=collis-family-xxxxxxxx

# Alexa Shopping List
# 1. Go to https://developer.amazon.com/loginwithamazon/console/site/lwa/overview.html
# 2. Create a Security Profile (name it "Collis Family Planner" or similar)
# 3. Under "Web Settings", add Allowed Return URL: {APP_BASE_URL}/alexa/oauth2callback
# 4. Copy the Client ID and Client Secret below
ALEXA_CLIENT_ID=
ALEXA_CLIENT_SECRET=

# Admin PIN (Katie & Paul use this to make admin changes)
ADMIN_PIN=choose-a-pin

# UniFi (only needed for WiFi/device controls)
UNIFI_HOST=192.168.1.1
UNIFI_API_KEY=
UNIFI_SITE=default
# WiFi networks admins can toggle (comma-separated)
MANAGED_WLANS=TCN_Junior

# Known devices for UniFi controls (format: "Name:mac,Name:mac")
# KNOWN_DEVICES=Joshua's iPad:aa:bb:cc:dd:ee:ff,Violet's Tablet:11:22:33:44:55:66
